{
  "name": "@nanopub/nanopub-elements",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/nanopub-elements.js",
  "module": "./dist/nanopub-elements.js",
  "exports": {
    ".": {
      "browser": "./dist/nanopub-elements.js",
      "default": "./dist/nanopub-elements.js"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "yarn@4.12.0",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --format=esm --outfile=dist/nanopub-elements.js",
    "build:watch": "esbuild src/index.ts --bundle --format=esm --outfile=dist/nanopub-elements.js --watch",
    "typecheck": "tsc --noEmit",
    "serve": "npx serve .",
    "prepack": "yarn build"
  },
  "dependencies": {
    "@nanopub/nanopub-js": "^0.1.1",
    "dompurify": "^3.3.1"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/n3": "^1.26.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knowledgepixels/nanopub-elements"
  }
}
